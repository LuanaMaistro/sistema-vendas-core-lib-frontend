{
  "name": "@dibimo/core-lib",
  "version": "0.0.35",
  "description": "Core business logic library",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./domain": {
      "import": "./dist/domain/index.mjs",
      "require": "./dist/domain/index.js",
      "types": "./dist/domain/index.d.ts"
    },
    "./application": {
      "import": "./dist/application/index.mjs",
      "require": "./dist/application/index.js",
      "types": "./dist/application/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist"
  },

  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "@Dibimo:registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Dibimo/sistema-vendas-core-lib-frontend.git"
  },

  "keywords": [
    "domain",
    "application",
    "clean-architecture"
  ],
  "author": "Luana Maistro",
  "license": "MIT",
  "devDependencies": {
    "tsup": "^8.0.1",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "reflect-metadata": "^0.2.2"
  }
}
